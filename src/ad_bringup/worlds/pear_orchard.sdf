<?xml version="1.0"?>
<!--
  pear_orchard.sdf — 배 과수원 시뮬레이션 월드
  6x6m 간격 나무 배치, 수고 2m, 줄기+수관부 구조
  crop_row_detector 카메라 온리 경로 생성 검증용
-->
<sdf version="1.9">
  <world name="pear_orchard">

    <!-- 물리 엔진 설정 -->
    <physics name="default_physics" type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
    </physics>

    <!-- 시뮬레이션 플러그인 -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system"
            name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-navsat-system"
            name="gz::sim::systems::NavSat"/>
    <plugin filename="gz-sim-contact-system"
            name="gz::sim::systems::Contact"/>

    <!-- GPS 기준점 (나주 배 과수원 근처) -->
    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <latitude_deg>34.9406</latitude_deg>
      <longitude_deg>126.7103</longitude_deg>
      <elevation>30</elevation>
      <heading_deg>0</heading_deg>
    </spherical_coordinates>

    <!-- 조명 -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 50 0 0 0</pose>
      <diffuse>0.9 0.9 0.85 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <light type="directional" name="ambient_fill">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 50 0 0 0</pose>
      <diffuse>0.3 0.3 0.35 1</diffuse>
      <specular>0.0 0.0 0.0 1</specular>
      <direction>0.3 -0.2 -0.8</direction>
    </light>

    <!-- 하늘 -->
    <scene>
      <ambient>0.6 0.6 0.65 1</ambient>
      <background>0.7 0.8 0.95 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- ================================================================ -->
    <!-- 지면: 60m x 60m 과수원 토양 (갈색) -->
    <!-- ================================================================ -->
    <model name="ground_plane">
      <static>true</static>
      <link name="ground_link">
        <collision name="ground_collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>60 60</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.5</mu>
                <mu2>1.5</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name="ground_visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>60 60</size>
            </plane>
          </geometry>
          <material>
            <!-- 과수원 토양 (갈색) -->
            <ambient>0.45 0.35 0.25 1</ambient>
            <diffuse>0.5 0.4 0.3 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ================================================================ -->
    <!-- 배 나무 모델 매크로: 줄기(cylinder) + 수관부(ellipsoid)            -->
    <!-- 배 과수원: 6x6m 간격, 수고 ~2m, 수관폭 ~2.5m                     -->
    <!-- 5행 x 8그루 = 40그루                                             -->
    <!-- 행 방향: X축 (전방), 행간 간격: Y축 6m                            -->
    <!-- 로봇 시작: (0, 3, 0) — 1행과 2행 사이 중앙                       -->
    <!-- ================================================================ -->

    <!-- === 행 1 (Y=0) === -->
    <model name="tree_r1_01"><static>true</static><pose>3 0 0 0 0 0</pose>
      <link name="trunk"><visual name="v"><geometry><cylinder><radius>0.08</radius><length>1.0</length></cylinder></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.45 0.3 0.15 1</diffuse></material></visual><pose>0 0 0.5 0 0 0</pose></link>
      <link name="canopy"><visual name="v"><geometry><sphere><radius>1.2</radius></sphere></geometry><material><ambient>0.15 0.45 0.1 1</ambient><diffuse>0.2 0.55 0.15 1</diffuse></material></visual><pose>0 0 1.6 0 0 0</pose></link>
    </model>
    <model name="tree_r1_02"><static>true</static><pose>9 0 0 0 0 0</pose>
      <link name="trunk"><visual name="v"><geometry><cylinder><radius>0.08</radius><length>1.0</length></cylinder></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.45 0.3 0.15 1</diffuse></material></visual><pose>0 0 0.5 0 0 0</pose></link>
      <link name="canopy"><visual name="v"><geometry><sphere><radius>1.2</radius></sphere></geometry><material><ambient>0.15 0.45 0.1 1</ambient><diffuse>0.2 0.55 0.15 1</diffuse></material></visual><pose>0 0 1.6 0 0 0</pose></link>
    </model>
    <model name="tree_r1_03"><static>true</static><pose>15 0 0 0 0 0</pose>
      <link name="trunk"><visual name="v"><geometry><cylinder><radius>0.08</radius><length>1.0</length></cylinder></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.45 0.3 0.15 1</diffuse></material></visual><pose>0 0 0.5 0 0 0</pose></link>
      <link name="canopy"><visual name="v"><geometry><sphere><radius>1.2</radius></sphere></geometry><material><ambient>0.15 0.45 0.1 1</ambient><diffuse>0.2 0.55 0.15 1</diffuse></material></visual><pose>0 0 1.6 0 0 0</pose></link>
    </model>
    <model name="tree_r1_04"><static>true</static><pose>21 0 0 0 0 0</pose>
      <link name="trunk"><visual name="v"><geometry><cylinder><radius>0.08</radius><length>1.0</length></cylinder></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.45 0.3 0.15 1</diffuse></material></visual><pose>0 0 0.5 0 0 0</pose></link>
      <link name="canopy"><visual name="v"><geometry><sphere><radius>1.2</radius></sphere></geometry><material><ambient>0.15 0.45 0.1 1</ambient><diffuse>0.2 0.55 0.15 1</diffuse></material></visual><pose>0 0 1.6 0 0 0</pose></link>
    </model>
    <model name="tree_r1_05"><static>true</static><pose>27 0 0 0 0 0</pose>
      <link name="trunk"><visual name="v"><geometry><cylinder><radius>0.08</radius><length>1.0</length></cylinder></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.45 0.3 0.15 1</diffuse></material></visual><pose>0 0 0.5 0 0 0</pose></link>
      <link name="canopy"><visual name="v"><geometry><sphere><radius>1.2</radius></sphere></geometry><material><ambient>0.15 0.45 0.1 1</ambient><diffuse>0.2 0.55 0.15 1</diffuse></material></visual><pose>0 0 1.6 0 0 0</pose></link>
    </model>
    <model name="tree_r1_06"><static>true</static><pose>33 0 0 0 0 0</pose>
      <link name="trunk"><visual name="v"><geometry><cylinder><radius>0.08</radius><length>1.0</length></cylinder></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.45 0.3 0.15 1</diffuse></material></visual><pose>0 0 0.5 0 0 0</pose></link>
      <link name="canopy"><visual name="v"><geometry><sphere><radius>1.2</radius></sphere></geometry><material><ambient>0.15 0.45 0.1 1</ambient><diffuse>0.2 0.55 0.15 1</diffuse></material></visual><pose>0 0 1.6 0 0 0</pose></link>
    </model>

    <!-- === 행 2 (Y=6) === -->
    <model name="tree_r2_01"><static>true</static><pose>3 6 0 0 0 0</pose>
      <link name="trunk"><visual name="v"><geometry><cylinder><radius>0.08</radius><length>1.0</length></cylinder></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.45 0.3 0.15 1</diffuse></material></visual><pose>0 0 0.5 0 0 0</pose></link>
      <link name="canopy"><visual name="v"><geometry><sphere><radius>1.2</radius></sphere></geometry><material><ambient>0.18 0.48 0.12 1</ambient><diffuse>0.22 0.58 0.17 1</diffuse></material></visual><pose>0 0 1.6 0 0 0</pose></link>
