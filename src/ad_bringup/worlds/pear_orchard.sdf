      <link name="canopy"><visual name="v"><geometry><sphere><radius>1.2</radius></sphere></geometry><material><ambient>0.18 0.48 0.12 1</ambient><diffuse>0.22 0.58 0.17 1</diffuse></material></visual><pose>0 0 1.6 0 0 0</pose></link>
    </model>
