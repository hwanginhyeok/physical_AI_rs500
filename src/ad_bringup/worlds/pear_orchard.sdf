      <link name="canopy"><visual name="v"><geometry><sphere><radius>1.1</radius></sphere></geometry><material><ambient>0.15 0.45 0.1 1</ambient><diffuse>0.2 0.55 0.15 1</diffuse></material></visual><pose>0 0 1.5 0 0 0</pose></link>
    </model>
    <model name="tree_r3_02"><static>true</static><pose>9 12 0 0 0 0</pose>
