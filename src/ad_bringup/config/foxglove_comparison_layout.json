  "userNodes": {
    "regression_node": {
      "name": "RegressionCompare",
      "sourceCode": "// Regression Compare: 두 데이터 소스의 위치/속도 비교 메트릭\n// Foxglove에서 sim/real bag 동시 열기 시 사용\n// Plot: /studio_script/regression.pos_diff, .vel_diff, .heading_diff\n\nimport { Input } from \"./types\";\n\nexport const inputs = [\"/odometry/local\"];\nexport const output = \"/studio_script/regression\";\n\nlet history: Array<{ x: number; y: number; vx: number; yaw: number; t: number }> = [];\nconst WINDOW = 100; // 최근 100개 메시지 기반\n\nfunction quaternionToYaw(q: any): number {\n  const siny = 2.0 * (q.w * q.z + q.x * q.y);\n  const cosy = 1.0 - 2.0 * (q.y * q.y + q.z * q.z);\n  return Math.atan2(siny, cosy);\n}\n\ntype InputEvent = Input<\"/odometry/local\">;\n\nexport default function script(event: InputEvent): {\n  pos_diff: number;\n  vel_diff: number;\n  heading_diff: number;\n  sample_count: number;\n} | undefined {\n  const msg = (event as any).message;\n  const x = msg.pose.pose.position.x;\n  const y = msg.pose.pose.position.y;\n  const vx = msg.twist.twist.linear.x;\n  const yaw = quaternionToYaw(msg.pose.pose.orientation);\n  const t = event.receiveTime.sec + event.receiveTime.nsec * 1e-9;\n\n  history.push({ x, y, vx, yaw, t });\n  if (history.length > WINDOW) history.shift();\n\n  if (history.length < 2) return undefined;\n\n  // 통계: 최근 윈도우 내 변동성 (자기 상관 기반 — 단일 소스에서도 유용)\n  const n = history.length;\n  let posDiffSum = 0;\n  let velDiffSum = 0;\n  let headingDiffSum = 0;\n\n  for (let i = 1; i < n; i++) {\n    const dx = history[i].x - history[i - 1].x;\n    const dy = history[i].y - history[i - 1].y;\n    posDiffSum += Math.sqrt(dx * dx + dy * dy);\n    velDiffSum += Math.abs(history[i].vx - history[i - 1].vx);\n\n    let hdiff = (history[i].yaw - history[i - 1].yaw) * 180 / Math.PI;\n    while (hdiff > 180) hdiff -= 360;\n    while (hdiff < -180) hdiff += 360;\n    headingDiffSum += Math.abs(hdiff);\n  }\n\n  const count = n - 1;\n  return {\n    pos_diff: Math.round((posDiffSum / count) * 1000) / 1000,\n    vel_diff: Math.round((velDiffSum / count) * 1000) / 1000,\n    heading_diff: Math.round((headingDiffSum / count) * 100) / 100,\n    sample_count: n,\n  };\n}\n"
    }
  },
  "playbackConfig": {
    "speed": 1.0
