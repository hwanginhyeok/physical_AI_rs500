{
  "_comment": [
    "시뮬레이션 vs 실물 비교 레이아웃 v2.0",
    "Camera-Only 센서 스택 (C64 반영)",
    "",
    "사용법:",
    "  1. Foxglove → Data Sources → [+] 으로 bag 2개 동시 열기",
    "     - Source 1: sim_YYYYMMDD_HHMMSS (시뮬레이션 bag)",
    "     - Source 2: real_YYYYMMDD_HHMMSS (실물 bag)",
    "  2. Layouts → Import → 이 파일 선택",
    "  3. 각 패널 우상단 소스 아이콘으로 시뮬/실물 전환",
    "  4. Plot 패널: + 시리즈 추가 → 소스 다르게 설정해 오버레이",
    "",
    "5탭 구조:",
    "  Navigation 비교 — 3D (sim | real) + 위치 비교 Plot",
    "  Camera 비교    — 전면 카메라 (sim | real) + 깊이 포인트클라우드",
    "  속도/제어 비교  — vx, wz, cmd_vel 4분할 비교",
    "  GPS 경로       — GPS 지도 + 네비게이션 로그",
    "  Diagnostics    — TF 트리 + 토픽 그래프 + 로그"
  ],

  "configById": {

    "3D!sim": {
      "followTf": "base_link",
      "scene": {
        "backgroundColor": "#0d1b2a",
        "enableStats": false,
        "labelScaleFactor": 1.0
      },
      "cameraState": {
        "distance": 25,
        "perspective": true,
        "phi": 55,
        "target": [0, 0, 0],
        "thetaOffset": 0
      },
      "publish": {
        "type": "pose",
        "poseTopic": "/goal_pose"
      },
      "topics": {
        "/waypoint_manager/markers": { "visible": true },
        "/global_costmap/costmap": { "visible": true, "colorMode": "costmap", "alpha": 0.35 },
        "/local_costmap/costmap": { "visible": true, "colorMode": "costmap", "alpha": 0.2 },
        "/plan": { "visible": true, "lineWidth": 3, "gradient": ["#00e676", "#00e676"] },
        "/local_plan": { "visible": true, "lineWidth": 2, "gradient": ["#ffab40", "#ffab40"] },
        "/sensor/camera/front/points": { "visible": true, "pointSize": 2, "colorMode": "flat", "flatColor": "#4fc3f7" },
        "/map": { "visible": true, "alpha": 0.5 }
      },
      "layers": {
        "grid": {
          "layerId": "foxglove.Grid",
          "visible": true,
          "size": 100,
          "divisions": 100,
          "color": "#1a237e44"
        },
        "urdf": {
          "layerId": "foxglove.Urdf",
          "visible": true,
          "sourceType": "param",
          "parameter": "/robot_description"
        }
      }
    },

    "3D!real": {
      "followTf": "base_link",
      "scene": {
        "backgroundColor": "#1a0a00",
        "enableStats": false
      },
      "cameraState": {
        "distance": 25,
        "perspective": true,
        "phi": 55,
        "target": [0, 0, 0],
        "thetaOffset": 0
      },
      "publish": {
        "type": "pose",
        "poseTopic": "/goal_pose"
      },
      "topics": {
        "/waypoint_manager/markers": { "visible": true },
        "/global_costmap/costmap": { "visible": true, "colorMode": "costmap", "alpha": 0.35 },
        "/local_costmap/costmap": { "visible": true, "colorMode": "costmap", "alpha": 0.2 },
        "/plan": { "visible": true, "lineWidth": 3, "gradient": ["#40c4ff", "#40c4ff"] },
        "/local_plan": { "visible": true, "lineWidth": 2, "gradient": ["#ffca28", "#ffca28"] },
        "/sensor/camera/front/points": { "visible": true, "pointSize": 2, "colorMode": "flat", "flatColor": "#ff6f00" },
        "/map": { "visible": true, "alpha": 0.5 }
      },
      "layers": {
        "grid": {
          "layerId": "foxglove.Grid",
          "visible": true,
          "size": 100,
          "divisions": 100,
          "color": "#4e342e44"
        },
        "urdf": {
          "layerId": "foxglove.Urdf",
          "visible": true,
          "sourceType": "param",
          "parameter": "/robot_description"
        }
      }
    },

    "Image!simFront": {
      "cameraTopic": "/sensor/camera/front/image",
      "enabledMarkerTopics": ["/perception/annotations/front"],
      "calibrationTopic": "/sensor/camera/front/camera_info",
      "synchronize": false,
      "smooth": true,
      "rotation": 0
    },
    "Image!realFront": {
      "cameraTopic": "/sensor/camera/front/image",
      "enabledMarkerTopics": ["/perception/annotations/front"],
      "calibrationTopic": "/sensor/camera/front/camera_info",
      "synchronize": false,
      "smooth": true,
      "rotation": 0
    },

    "3D!simDepth": {
      "followTf": "base_link",
      "scene": { "backgroundColor": "#0d1b2a", "enableStats": false },
      "cameraState": { "distance": 15, "perspective": true, "phi": 60, "target": [0, 0, 0], "thetaOffset": 0 },
      "topics": {
        "/sensor/camera/front/points": { "visible": true, "pointSize": 3, "colorMode": "flat", "flatColor": "#4fc3f7" },
        "/sensor/camera/left/points": { "visible": true, "pointSize": 3, "colorMode": "flat", "flatColor": "#66bb6a" },
        "/sensor/camera/right/points": { "visible": true, "pointSize": 3, "colorMode": "flat", "flatColor": "#ffa726" }
      },
      "layers": {
        "grid": { "layerId": "foxglove.Grid", "visible": true, "size": 30, "divisions": 30, "color": "#1a237e44" },
        "urdf": { "layerId": "foxglove.Urdf", "visible": true, "sourceType": "param", "parameter": "/robot_description" }
      }
    },
    "3D!realDepth": {
      "followTf": "base_link",
      "scene": { "backgroundColor": "#1a0a00", "enableStats": false },
      "cameraState": { "distance": 15, "perspective": true, "phi": 60, "target": [0, 0, 0], "thetaOffset": 0 },
      "topics": {
        "/sensor/camera/front/points": { "visible": true, "pointSize": 3, "colorMode": "flat", "flatColor": "#ff6f00" },
        "/sensor/camera/left/points": { "visible": true, "pointSize": 3, "colorMode": "flat", "flatColor": "#ffb74d" },
        "/sensor/camera/right/points": { "visible": true, "pointSize": 3, "colorMode": "flat", "flatColor": "#ffcc80" }
      },
      "layers": {
        "grid": { "layerId": "foxglove.Grid", "visible": true, "size": 30, "divisions": 30, "color": "#4e342e44" },
        "urdf": { "layerId": "foxglove.Urdf", "visible": true, "sourceType": "param", "parameter": "/robot_description" }
      }
    },

    "Plot!posX": {
      "title": "Position X (sim=green / real=orange)",
      "paths": [
        { "value": "/odometry/local.pose.pose.position.x", "label": "sim x (m)", "timestampMethod": "receiveTime", "color": "#00e676", "lineSize": 2.0 },
        { "value": "/odometry/local.pose.pose.position.x", "label": "real x (m)", "timestampMethod": "receiveTime", "color": "#ff6f00", "lineSize": 2.0 }
      ],
      "xAxisVal": "timestamp",
      "showLegend": true,
      "legendDisplay": "floating",
      "isSynced": true,
      "followingViewWidth": 60
    },
    "Plot!posY": {
      "title": "Position Y",
      "paths": [
        { "value": "/odometry/local.pose.pose.position.y", "label": "sim y (m)", "timestampMethod": "receiveTime", "color": "#00e676", "lineSize": 2.0 },
        { "value": "/odometry/local.pose.pose.position.y", "label": "real y (m)", "timestampMethod": "receiveTime", "color": "#ff6f00", "lineSize": 2.0 }
      ],
      "xAxisVal": "timestamp",
      "showLegend": true,
      "legendDisplay": "floating",
      "isSynced": true,
      "followingViewWidth": 60
    },

    "Plot!velX": {
      "title": "Forward Velocity vx (m/s)",
      "paths": [
        { "value": "/odometry/local.twist.twist.linear.x", "label": "sim vx", "timestampMethod": "receiveTime", "color": "#4fc3f7", "lineSize": 1.5 },
        { "value": "/odometry/local.twist.twist.linear.x", "label": "real vx", "timestampMethod": "receiveTime", "color": "#ffb74d", "lineSize": 1.5 }
      ],
      "xAxisVal": "timestamp",
      "showLegend": true,
      "legendDisplay": "floating",
      "isSynced": true,
      "minYValue": -2.0,
      "maxYValue": 4.0,
      "followingViewWidth": 30
    },
    "Plot!velZ": {
      "title": "Angular Velocity wz (rad/s)",
      "paths": [
        { "value": "/odometry/local.twist.twist.angular.z", "label": "sim wz", "timestampMethod": "receiveTime", "color": "#ce93d8", "lineSize": 1.5 },
        { "value": "/odometry/local.twist.twist.angular.z", "label": "real wz", "timestampMethod": "receiveTime", "color": "#ef9a9a", "lineSize": 1.5 }
      ],
      "xAxisVal": "timestamp",
      "showLegend": true,
      "legendDisplay": "floating",
      "isSynced": true,
      "minYValue": -2.5,
      "maxYValue": 2.5,
      "followingViewWidth": 30
    },
    "Plot!cmdVel": {
      "title": "cmd_vel Command",
      "paths": [
        { "value": "/cmd_vel.linear.x", "label": "sim cmd vx", "timestampMethod": "receiveTime", "color": "#00bcd4", "lineSize": 1.5 },
        { "value": "/cmd_vel.linear.x", "label": "real cmd vx", "timestampMethod": "receiveTime", "color": "#ff9800", "lineSize": 1.5 }
      ],
      "xAxisVal": "timestamp",
      "showLegend": true,
      "legendDisplay": "floating",
      "isSynced": true,
      "followingViewWidth": 30
    },
    "Plot!cmdWzComp": {
      "title": "cmd_vel Angular",
      "paths": [
        { "value": "/cmd_vel.angular.z", "label": "sim cmd wz", "timestampMethod": "receiveTime", "color": "#00bcd4", "lineSize": 1.5 },
        { "value": "/cmd_vel.angular.z", "label": "real cmd wz", "timestampMethod": "receiveTime", "color": "#ff9800", "lineSize": 1.5 }
      ],
      "xAxisVal": "timestamp",
      "showLegend": true,
      "legendDisplay": "floating",
      "isSynced": true,
      "followingViewWidth": 30
    },

    "Map!gpsCompare": {
      "layer": "map",
      "topicPath": "/sensor/gps",
      "zoomLevel": 18
    },

    "RawMessages!wpStatusSim": {
      "topicPath": "/waypoint_manager/status",
      "diffEnabled": false,
      "fontSize": 12
    },
    "RawMessages!wpStatusReal": {
      "topicPath": "/waypoint_manager/status",
      "diffEnabled": false,
      "fontSize": 12
    },

    "TransformTree!tfTree": {},
    "TopicGraph!tgraph": {},

    "Log!navLog": {
      "searchTerms": [],
      "minLogLevel": 1,
      "nameFilter": {
        "waypoint_manager": true,
        "bt_navigator": true,
        "controller_server": true,
        "planner_server": true
      }
    },

    "Tab!mainTab": {
      "activeTabIdx": 0,
      "tabs": [
        {
          "title": "Navigation",
          "layout": {
            "direction": "column",
            "first": {
              "direction": "row",
              "first": "3D!sim",
              "second": "3D!real",
              "splitPercentage": 50
            },
            "second": {
              "direction": "row",
              "first": "Plot!posX",
              "second": "Plot!posY",
              "splitPercentage": 50
            },
            "splitPercentage": 65
          }
        },
        {
          "title": "Camera",
          "layout": {
            "direction": "column",
            "first": {
              "direction": "row",
              "first": "Image!simFront",
              "second": "Image!realFront",
              "splitPercentage": 50
            },
            "second": {
              "direction": "row",
              "first": "3D!simDepth",
              "second": "3D!realDepth",
              "splitPercentage": 50
            },
            "splitPercentage": 50
          }
        },
        {
          "title": "Control",
          "layout": {
            "direction": "column",
            "first": {
              "direction": "row",
              "first": "Plot!velX",
              "second": "Plot!velZ",
              "splitPercentage": 50
            },
            "second": {
              "direction": "row",
              "first": "Plot!cmdVel",
              "second": "Plot!cmdWzComp",
              "splitPercentage": 50
            },
            "splitPercentage": 50
          }
        },
        {
          "title": "GPS",
          "layout": {
            "direction": "row",
            "first": "Map!gpsCompare",
            "second": {
              "direction": "column",
              "first": {
                "direction": "row",
                "first": "RawMessages!wpStatusSim",
                "second": "RawMessages!wpStatusReal",
                "splitPercentage": 50
              },
              "second": "Log!navLog",
              "splitPercentage": 50
            },
            "splitPercentage": 60
          }
        },
        {
          "title": "Diagnostics",
          "layout": {
            "direction": "row",
            "first": "TransformTree!tfTree",
            "second": {
              "direction": "column",
              "first": "TopicGraph!tgraph",
              "second": "Log!navLog",
              "splitPercentage": 55
            },
            "splitPercentage": 45
          }
        }
      ]
    }
  },

  "globalVariables": {},
  "userNodes": {},
  "playbackConfig": {
    "speed": 1.0
  },
  "layout": "Tab!mainTab"
}
