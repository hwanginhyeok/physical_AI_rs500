      },
      "layers": {
        "grid": {
          "layerId": "foxglove.Grid",
          "visible": true,
          "size": 100,
          "divisions": 100,
          "color": "#333355"
        },
        "urdf": {
          "layerId": "foxglove.Urdf",
          "visible": true,
          "sourceType": "param",
          "parameter": "/robot_description"
        }
      }
    },
    "TransformTree!tfTree": {},
    "TopicGraph!tgraph": {},
    "Parameters!params": {},
    "Log!allLog": {
      "searchTerms": [],
      "minLogLevel": 0
    },
    "Log!navLog": {
      "searchTerms": [],
      "minLogLevel": 1,
      "nameFilter": {
        "waypoint_manager": true,
        "bt_navigator": true,
        "controller_server": true,
        "planner_server": true,
        "behavior_server": true,
        "velocity_smoother": true,
        "collision_monitor": true
      }
    },
    "Tab!mainTab": {
      "activeTabIdx": 0,
      "tabs": [
        {
          "title": "Raw Sensors",
          "layout": {
            "direction": "column",
            "first": {
              "direction": "row",
              "first": "Image!camFront",
              "second": {
                "direction": "row",
                "first": "Image!camLeft",
                "second": "Image!camRight",
                "splitPercentage": 50
              },
              "splitPercentage": 40
            },
            "second": {
              "direction": "column",
              "first": {
                "direction": "row",
                "first": "RawMessages!rawImu",
                "second": {
                  "direction": "row",
                  "first": "RawMessages!rawGps",
                  "second": "RawMessages!rawOdom",
                  "splitPercentage": 50
                },
                "splitPercentage": 34
              },
              "second": {
                "direction": "row",
                "first": "Plot!imuAccel",
                "second": "Plot!imuGyro",
                "splitPercentage": 50
              },
              "splitPercentage": 45
            },
            "splitPercentage": 38
          }
        },
        {
          "title": "Depth & TF",
          "layout": {
            "direction": "row",
            "first": {
              "direction": "column",
              "first": "3D!depthAll",
              "second": "Plot!imuOrientation",
              "splitPercentage": 70
            },
            "second": {
              "direction": "column",
              "first": "TransformTree!tfTree",
              "second": {
                "direction": "column",
                "first": "RawMessages!rawEkfLocal",
                "second": "RawMessages!rawEkfGlobal",
                "splitPercentage": 50
              },
              "splitPercentage": 55
            },
            "splitPercentage": 55
          }
        },
        {
          "title": "Nav2 Internal",
          "layout": {
            "direction": "row",
            "first": {
              "direction": "column",
              "first": "3D!nav2Deep",
              "second": {
                "direction": "row",
                "first": "Plot!ekfLocalVsGlobal",
                "second": "Plot!gpsCoords",
                "splitPercentage": 50
              },
              "splitPercentage": 65
            },
            "second": {
              "direction": "column",
              "first": {
                "direction": "row",
                "first": "RawMessages!rawWpStatus",
                "second": "RawMessages!btLog",
                "splitPercentage": 50
              },
              "second": {
                "direction": "column",
                "first": "RawMessages!rawCmdVel",
                "second": "Log!navLog",
                "splitPercentage": 45
              },
              "splitPercentage": 35
            },
            "splitPercentage": 65
          }
        },
        {
          "title": "Topic & Param",
          "layout": {
            "direction": "row",
            "first": "TopicGraph!tgraph",
            "second": {
              "direction": "column",
              "first": "Parameters!params",
              "second": "Log!allLog",
              "splitPercentage": 50
            },
            "splitPercentage": 50
          }
        },
        {
          "title": "Velocity Chain",
          "layout": {
            "direction": "column",
            "first": {
              "direction": "row",
              "first": "Plot!cmdVelChain",
              "second": "Plot!cmdWzChain",
              "splitPercentage": 50
            },
            "second": {
              "direction": "row",
              "first": {
                "direction": "row",
                "first": "RawMessages!rawCmdVel",
                "second": "RawMessages!rawCmdSmoothed",
                "splitPercentage": 50
              },
              "second": "RawMessages!rawEkfLocal",
              "splitPercentage": 67
            },
            "splitPercentage": 55
          }
        }
      ]
    },
    "RawMessages!btLog": {
      "topicPath": "/behavior_tree_log",
