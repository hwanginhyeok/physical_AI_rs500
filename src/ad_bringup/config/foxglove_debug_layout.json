{
  "_comment": [
    "자율주행 Foxglove [DEBUG] 레이아웃 v3.0",
    "Camera-Only 센서 스택 (C64 반영)",
    "",
    "용도: 문제 발생 시 심층 디버깅",
    "특징:",
    "  - 원시 센서 데이터 전수 노출 (IMU 자이로/가속도, GPS raw, odom raw)",
    "  - TF 트리 + 토픽 그래프 + 파라미터 전체 조회",
    "  - Nav2 내부 상태 (controller/planner/bt 개별 Raw)",
    "  - 깊이 포인트클라우드 3대 근접 뷰",
    "  - 대역폭 높음 — 문제 재현 시에만 사용 권장",
    "",
    "5탭 구조:",
    "  Raw Sensors   — 카메라 3대 + IMU/GPS/Odom 원시 데이터",
    "  Depth & TF    — 깊이 포인트클라우드 근접 + TF 트리",
    "  Nav2 Internal — costmap + planner/controller/bt 원시 상태",
    "  Topic & Param — 토픽 그래프 + 파라미터 + 전체 로그",
    "  Timing        — 센서 지연 + IMU 주파수 + 제어 루프 타이밍",
    "",
    "접속: Foxglove → Open connection → ws://localhost:8765"
  ],
  "configById": {
    "Image!camFront": {
      "cameraTopic": "/sensor/camera/front/image",
      "enabledMarkerTopics": [
        "/perception/annotations/front"
      ],
      "calibrationTopic": "/sensor/camera/front/camera_info",
      "synchronize": false,
      "smooth": true,
      "rotation": 0
    },
    "Image!camLeft": {
      "cameraTopic": "/sensor/camera/left/image",
      "enabledMarkerTopics": [
        "/perception/annotations/left"
      ],
      "synchronize": false,
      "smooth": true,
      "rotation": 0,
      "calibrationTopic": "/sensor/camera/left/camera_info"
    },
    "Image!camRight": {
      "cameraTopic": "/sensor/camera/right/image",
      "enabledMarkerTopics": [
        "/perception/annotations/right"
      ],
      "synchronize": false,
      "smooth": true,
      "rotation": 0,
      "calibrationTopic": "/sensor/camera/right/camera_info"
    },
    "RawMessages!rawImu": {
      "topicPath": "/sensor/imu",
      "diffEnabled": false,
      "showFullMessageForDiff": false,
      "fontSize": 11
    },
    "RawMessages!rawGps": {
      "topicPath": "/sensor/gps",
      "diffEnabled": false,
      "showFullMessageForDiff": false,
      "fontSize": 11
    },
    "RawMessages!rawOdom": {
      "topicPath": "/odom",
      "diffEnabled": false,
      "showFullMessageForDiff": false,
      "fontSize": 11
    },
    "RawMessages!rawEkfLocal": {
      "topicPath": "/odometry/local",
      "diffEnabled": false,
      "showFullMessageForDiff": false,
      "fontSize": 11
    },
    "RawMessages!rawEkfGlobal": {
      "topicPath": "/odometry/global",
      "diffEnabled": false,
      "showFullMessageForDiff": false,
      "fontSize": 11
    },
    "RawMessages!rawCmdVel": {
      "topicPath": "/cmd_vel",
      "diffEnabled": false,
      "showFullMessageForDiff": false,
      "fontSize": 11
    },
    "RawMessages!rawCmdSmoothed": {
      "topicPath": "/cmd_vel_smoothed",
      "diffEnabled": false,
      "showFullMessageForDiff": false,
      "fontSize": 11
    },
    "RawMessages!rawWpStatus": {
      "topicPath": "/waypoint_manager/status",
      "diffEnabled": false,
      "showFullMessageForDiff": false,
      "fontSize": 11
    },
    "Plot!imuAccel": {
      "title": "IMU Linear Acceleration (m/s²)",
      "paths": [
        {
          "value": "/sensor/imu.linear_acceleration.x",
          "label": "ax",
          "timestampMethod": "receiveTime",
          "color": "#ef5350",
          "lineSize": 1.0
        },
        {
          "value": "/sensor/imu.linear_acceleration.y",
          "label": "ay",
          "timestampMethod": "receiveTime",
          "color": "#66bb6a",
          "lineSize": 1.0
        },
        {
          "value": "/sensor/imu.linear_acceleration.z",
          "label": "az",
          "timestampMethod": "receiveTime",
          "color": "#42a5f5",
          "lineSize": 1.0
        }
      ],
      "xAxisVal": "timestamp",
      "showLegend": true,
      "legendDisplay": "floating",
      "followingViewWidth": 10
    },
    "Plot!imuGyro": {
      "title": "IMU Angular Velocity (rad/s)",
      "paths": [
        {
          "value": "/sensor/imu.angular_velocity.x",
          "label": "gx (roll)",
          "timestampMethod": "receiveTime",
          "color": "#ef5350",
          "lineSize": 1.0
        },
        {
          "value": "/sensor/imu.angular_velocity.y",
          "label": "gy (pitch)",
          "timestampMethod": "receiveTime",
          "color": "#66bb6a",
          "lineSize": 1.0
        },
        {
          "value": "/sensor/imu.angular_velocity.z",
          "label": "gz (yaw)",
          "timestampMethod": "receiveTime",
          "color": "#42a5f5",
          "lineSize": 1.0
        }
      ],
      "xAxisVal": "timestamp",
      "showLegend": true,
      "legendDisplay": "floating",
      "followingViewWidth": 10
    },
    "Plot!imuOrientation": {
      "title": "IMU Orientation (quaternion)",
      "paths": [
        {
          "value": "/sensor/imu.orientation.x",
          "label": "qx",
          "timestampMethod": "receiveTime",
          "color": "#ef5350",
          "lineSize": 1.0
        },
        {
          "value": "/sensor/imu.orientation.y",
          "label": "qy",
          "timestampMethod": "receiveTime",
          "color": "#66bb6a",
          "lineSize": 1.0
        },
        {
          "value": "/sensor/imu.orientation.z",
          "label": "qz",
          "timestampMethod": "receiveTime",
          "color": "#42a5f5",
          "lineSize": 1.0
        },
        {
          "value": "/sensor/imu.orientation.w",
          "label": "qw",
          "timestampMethod": "receiveTime",
          "color": "#ffa726",
          "lineSize": 1.0
        }
      ],
      "xAxisVal": "timestamp",
      "showLegend": true,
      "legendDisplay": "floating",
      "followingViewWidth": 10
    },
    "Plot!gpsCoords": {
      "title": "GPS Coordinates",
      "paths": [
        {
          "value": "/sensor/gps.latitude",
          "label": "lat",
          "timestampMethod": "receiveTime",
          "color": "#ef5350",
          "lineSize": 1.5
        },
        {
          "value": "/sensor/gps.longitude",
          "label": "lon",
          "timestampMethod": "receiveTime",
          "color": "#66bb6a",
          "lineSize": 1.5
        }
      ],
      "xAxisVal": "timestamp",
      "showLegend": true,
      "legendDisplay": "floating",
      "followingViewWidth": 60
    },
    "Plot!ekfLocalVsGlobal": {
      "title": "EKF Local vs Global X",
      "paths": [
        {
          "value": "/odometry/local.pose.pose.position.x",
          "label": "local x",
          "timestampMethod": "receiveTime",
          "color": "#4fc3f7",
          "lineSize": 1.5
        },
        {
          "value": "/odometry/global.pose.pose.position.x",
          "label": "global x",
          "timestampMethod": "receiveTime",
          "color": "#ff8a65",
          "lineSize": 1.5
        }
      ],
      "xAxisVal": "timestamp",
      "showLegend": true,
      "legendDisplay": "floating",
      "followingViewWidth": 60
    },
    "Plot!cmdVelChain": {
      "title": "Velocity Chain: cmd → smoothed → actual",
      "paths": [
        {
          "value": "/cmd_vel.linear.x",
          "label": "cmd_vel",
          "timestampMethod": "receiveTime",
          "color": "#ef5350",
          "lineSize": 2.0
        },
        {
          "value": "/cmd_vel_smoothed.linear.x",
          "label": "smoothed",
          "timestampMethod": "receiveTime",
          "color": "#ffca28",
          "lineSize": 1.5
        },
        {
          "value": "/odometry/local.twist.twist.linear.x",
          "label": "actual",
          "timestampMethod": "receiveTime",
          "color": "#4fc3f7",
          "lineSize": 2.0
        },
        {
          "value": "/odom.twist.twist.linear.x",
          "label": "raw odom",
          "timestampMethod": "receiveTime",
          "color": "#78909c",
          "lineSize": 1.0
        }
      ],
      "xAxisVal": "timestamp",
      "showLegend": true,
      "legendDisplay": "floating",
      "minYValue": -2.0,
      "maxYValue": 4.0,
      "followingViewWidth": 15
    },
    "Plot!cmdWzChain": {
      "title": "Angular Chain: cmd → smoothed → actual",
      "paths": [
        {
          "value": "/cmd_vel.angular.z",
          "label": "cmd_vel",
          "timestampMethod": "receiveTime",
          "color": "#ef5350",
          "lineSize": 2.0
        },
        {
          "value": "/cmd_vel_smoothed.angular.z",
          "label": "smoothed",
          "timestampMethod": "receiveTime",
          "color": "#ffca28",
          "lineSize": 1.5
        },
        {
          "value": "/odometry/local.twist.twist.angular.z",
          "label": "actual",
          "timestampMethod": "receiveTime",
          "color": "#ce93d8",
          "lineSize": 2.0
        },
        {
          "value": "/odom.twist.twist.angular.z",
          "label": "raw odom",
          "timestampMethod": "receiveTime",
          "color": "#78909c",
          "lineSize": 1.0
        }
      ],
      "xAxisVal": "timestamp",
      "showLegend": true,
      "legendDisplay": "floating",
      "minYValue": -2.5,
      "maxYValue": 2.5,
      "followingViewWidth": 15
    },
    "3D!depthAll": {
      "followTf": "base_link",
      "scene": {
        "backgroundColor": "#050510",
        "enableStats": true
      },
      "cameraState": {
        "distance": 10,
        "perspective": true,
        "phi": 45,
        "target": [
          2,
          0,
          0
        ],
        "thetaOffset": 0
      },
      "topics": {
        "/sensor/camera/front/points": {
          "visible": true,
          "pointSize": 4,
          "colorMode": "flat",
          "flatColor": "#4fc3f7"
        },
        "/sensor/camera/left/points": {
          "visible": true,
          "pointSize": 4,
          "colorMode": "flat",
          "flatColor": "#66bb6a"
        },
        "/sensor/camera/right/points": {
          "visible": true,
          "pointSize": 4,
          "colorMode": "flat",
          "flatColor": "#ffa726"
        },
        "/perception/markers": {
          "visible": true
        }
      },
      "layers": {
        "grid": {
          "layerId": "foxglove.Grid",
          "visible": true,
          "size": 30,
          "divisions": 60,
          "color": "#222244"
        },
        "urdf": {
          "layerId": "foxglove.Urdf",
          "visible": true,
          "sourceType": "param",
          "parameter": "/robot_description"
        }
      }
    },
    "3D!nav2Deep": {
