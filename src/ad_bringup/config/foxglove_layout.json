  "globalVariables": {},
  "userNodes": {
    "cte_node": {
      "name": "CrossTrackError",
      "sourceCode": "// Cross-Track Error: /odometry/local 위치와 /plan 경로 간 최소 거리\n// Plot 패널에서 /studio_script/cte.cte 로 참조\n\nimport { Input } from \"./types\";\n\nexport const inputs = [\"/odometry/local\", \"/plan\"];\nexport const output = \"/studio_script/cte\";\n\nlet latestPlan: any = null;\n\ntype InputEvent = Input<\"/odometry/local\"> | Input<\"/plan\">;\n\nexport default function script(event: InputEvent): { cte: number } | undefined {\n  if (event.topic === \"/plan\") {\n    latestPlan = (event as any).message;\n    return undefined;\n  }\n\n  if (!latestPlan || !latestPlan.poses || latestPlan.poses.length === 0) {\n    return undefined;\n  }\n\n  const pos = (event as any).message.pose.pose.position;\n  let minDist = Infinity;\n\n  for (const p of latestPlan.poses) {\n    const dx = pos.x - p.pose.position.x;\n    const dy = pos.y - p.pose.position.y;\n    const d = Math.sqrt(dx * dx + dy * dy);\n    if (d < minDist) minDist = d;\n  }\n\n  return { cte: minDist };\n}\n"
    },
    "vel_error_node": {
      "name": "VelocityTrackingError",
      "sourceCode": "// Velocity Tracking Error: cmd_vel 명령과 실제 odom 속도 차이 + 10초 롤링 평균\n// Plot: /studio_script/vel_error.vx_error, .wz_error, .vx_error_avg, .wz_error_avg\n\nimport { Input } from \"./types\";\n\nexport const inputs = [\"/cmd_vel\", \"/odometry/local\"];\nexport const output = \"/studio_script/vel_error\";\n\nlet latestCmd: any = null;\nconst WINDOW_SEC = 10;\nconst vxHistory: Array<{ t: number; v: number }> = [];\nconst wzHistory: Array<{ t: number; v: number }> = [];\n\ntype InputEvent = Input<\"/cmd_vel\"> | Input<\"/odometry/local\">;\n\nexport default function script(event: InputEvent): {\n  vx_error: number;\n  wz_error: number;\n  vx_error_avg: number;\n  wz_error_avg: number;\n} | undefined {\n  if (event.topic === \"/cmd_vel\") {\n    latestCmd = (event as any).message;\n    return undefined;\n  }\n\n  if (!latestCmd) return undefined;\n\n  const now = event.receiveTime.sec + event.receiveTime.nsec * 1e-9;\n  const twist = (event as any).message.twist.twist;\n  const vx_error = Math.abs(latestCmd.linear.x - twist.linear.x);\n  const wz_error = Math.abs(latestCmd.angular.z - twist.angular.z);\n\n  // 히스토리 추가\n  vxHistory.push({ t: now, v: vx_error });\n  wzHistory.push({ t: now, v: wz_error });\n\n  // 윈도우 밖 제거\n  const cutoff = now - WINDOW_SEC;\n  while (vxHistory.length > 0 && vxHistory[0].t < cutoff) vxHistory.shift();\n  while (wzHistory.length > 0 && wzHistory[0].t < cutoff) wzHistory.shift();\n\n  // 롤링 평균\n  const vx_avg = vxHistory.reduce((s, e) => s + e.v, 0) / (vxHistory.length || 1);\n  const wz_avg = wzHistory.reduce((s, e) => s + e.v, 0) / (wzHistory.length || 1);\n\n  return {\n    vx_error: Math.round(vx_error * 1000) / 1000,\n    wz_error: Math.round(wz_error * 1000) / 1000,\n    vx_error_avg: Math.round(vx_avg * 1000) / 1000,\n    wz_error_avg: Math.round(wz_avg * 1000) / 1000,\n  };\n}\n"
    },
    "heading_error_node": {
      "name": "HeadingFromPlan",
      "sourceCode": "// Heading Error: 차량 방향과 경로 방향 간 오차 (degrees)\n// Plot 패널에서 /studio_script/heading.error_deg 로 참조\n\nimport { Input } from \"./types\";\n\nexport const inputs = [\"/odometry/local\", \"/plan\"];\nexport const output = \"/studio_script/heading\";\n\nlet latestPlan: any = null;\n\nfunction quaternionToYaw(q: any): number {\n  const siny = 2.0 * (q.w * q.z + q.x * q.y);\n  const cosy = 1.0 - 2.0 * (q.y * q.y + q.z * q.z);\n  return Math.atan2(siny, cosy);\n}\n\ntype InputEvent = Input<\"/odometry/local\"> | Input<\"/plan\">;\n\nexport default function script(event: InputEvent): { error_deg: number; robot_deg: number; path_deg: number } | undefined {\n  if (event.topic === \"/plan\") {\n    latestPlan = (event as any).message;\n    return undefined;\n  }\n\n  if (!latestPlan || !latestPlan.poses || latestPlan.poses.length < 2) return undefined;\n\n  const msg = (event as any).message;\n  const pos = msg.pose.pose.position;\n  const robotYaw = quaternionToYaw(msg.pose.pose.orientation);\n\n  // 가장 가까운 경로점 찾기\n  let minDist = Infinity;\n  let nearIdx = 0;\n  for (let i = 0; i < latestPlan.poses.length; i++) {\n    const p = latestPlan.poses[i].pose.position;\n    const d = Math.sqrt((pos.x - p.x) ** 2 + (pos.y - p.y) ** 2);\n    if (d < minDist) { minDist = d; nearIdx = i; }\n  }\n\n  // 경로 방향 (현재 점 → 다음 점)\n  const nextIdx = Math.min(nearIdx + 1, latestPlan.poses.length - 1);\n  const p0 = latestPlan.poses[nearIdx].pose.position;\n  const p1 = latestPlan.poses[nextIdx].pose.position;\n  const pathYaw = Math.atan2(p1.y - p0.y, p1.x - p0.x);\n\n  // 각도 오차 (-180 ~ +180)\n  let err = (robotYaw - pathYaw) * 180 / Math.PI;\n  while (err > 180) err -= 360;\n  while (err < -180) err += 360;\n\n  return {\n    error_deg: err,\n    robot_deg: robotYaw * 180 / Math.PI,\n    path_deg: pathYaw * 180 / Math.PI,\n  };\n}\n"
    },
    "coverage_node": {
      "name": "CoverageEstimator",
      "sourceCode": "// Coverage Estimator: 주행 거리 + 추정 커버리지 면적\n// Plot: /studio_script/coverage.distance_m, .area_m2, .speed_mps\n\nimport { Input } from \"./types\";\n\nexport const inputs = [\"/odometry/local\"];\nexport const output = \"/studio_script/coverage\";\n\nlet prevX: number | null = null;\nlet prevY: number | null = null;\nlet totalDistance = 0;\nconst VEHICLE_WIDTH = 1.2; // meters (작업 폭)\nlet startTime: number | null = null;\n\ntype InputEvent = Input<\"/odometry/local\">;\n\nexport default function script(event: InputEvent): {\n  distance_m: number;\n  area_m2: number;\n  speed_mps: number;\n} | undefined {\n  const msg = (event as any).message;\n  const x = msg.pose.pose.position.x;\n  const y = msg.pose.pose.position.y;\n  const vx = msg.twist.twist.linear.x;\n\n  if (startTime === null) {\n    startTime = event.receiveTime.sec + event.receiveTime.nsec * 1e-9;\n  }\n\n  if (prevX !== null && prevY !== null) {\n    const dx = x - prevX;\n    const dy = y - prevY;\n    const step = Math.sqrt(dx * dx + dy * dy);\n    if (step < 5.0) { // 5m 이상 점프는 무시 (리셋 등)\n      totalDistance += step;\n    }\n  }\n\n  prevX = x;\n  prevY = y;\n\n  return {\n    distance_m: Math.round(totalDistance * 10) / 10,\n    area_m2: Math.round(totalDistance * VEHICLE_WIDTH * 10) / 10,\n    speed_mps: Math.round(Math.abs(vx) * 100) / 100,\n  };\n}\n"
    },
    "geofence_node": {
      "name": "GeofenceChecker",
      "sourceCode": "// Geofence Checker: GPS 위치가 설정된 폴리곤 내부인지 확인\n// globalVariables에 geofence_lat, geofence_lon 배열 설정 필요\n// Indicator: /studio_script/geofence.inside (boolean)\n\nimport { Input } from \"./types\";\n\nexport const inputs = [\"/sensor/gps\"];\nexport const output = \"/studio_script/geofence\";\n\n// 기본 사각형 지오펜스 (globalVariables 미설정 시 사용)\n// 영월 기준 대략적인 테스트 영역\nconst DEFAULT_FENCE = [\n  { lat: 37.180, lon: 128.460 },\n  { lat: 37.185, lon: 128.460 },\n  { lat: 37.185, lon: 128.465 },\n  { lat: 37.180, lon: 128.465 },\n];\n\nfunction pointInPolygon(lat: number, lon: number, polygon: Array<{lat: number, lon: number}>): boolean {\n  let inside = false;\n  const n = polygon.length;\n  for (let i = 0, j = n - 1; i < n; j = i++) {\n    const yi = polygon[i].lat, xi = polygon[i].lon;\n    const yj = polygon[j].lat, xj = polygon[j].lon;\n    if (((yi > lat) !== (yj > lat)) && (lon < (xj - xi) * (lat - yi) / (yj - yi) + xi)) {\n      inside = !inside;\n    }\n  }\n  return inside;\n}\n\ntype InputEvent = Input<\"/sensor/gps\">;\n\nexport default function script(event: InputEvent): {\n  inside: boolean;\n  latitude: number;\n  longitude: number;\n} | undefined {\n  const msg = (event as any).message;\n  const lat = msg.latitude;\n  const lon = msg.longitude;\n\n  if (lat === 0 && lon === 0) return undefined; // GPS 미수신\n\n  const fence = DEFAULT_FENCE;\n  const inside = pointInPolygon(lat, lon, fence);\n\n  return { inside, latitude: lat, longitude: lon };\n}\n"
    },
    "perception_mode_node": {
      "name": "PerceptionModeDisplay",
      "sourceCode": "// Perception Mode Display: Hybrid E2E 상태 토픽에서 현재 모드 추출\n// Indicator: /studio_script/perception_mode.mode\n// Phase 3.1에서 /hybrid_e2e/status 토픽 발행 후 동작\n\nimport { Input } from \"./types\";\n\nexport const inputs = [\"/hybrid_e2e/status\"];\nexport const output = \"/studio_script/perception_mode\";\n\ntype InputEvent = Input<\"/hybrid_e2e/status\">;\n\nexport default function script(event: InputEvent): {\n  mode: string;\n  safety: string;\n  label: string;\n} | undefined {\n  const msg = (event as any).message;\n\n  try {\n    const status = JSON.parse(msg.data);\n    const mode = status.mode || \"unknown\";\n    const safety = status.safety_state || \"unknown\";\n\n    const modeLabels: Record<string, string> = {\n      learned: \"AI\",\n      traditional: \"Classic\",\n      fallback: \"FALLBACK\",\n      auto: \"Auto\",\n    };\n\n    return {\n      mode,\n      safety,\n      label: modeLabels[mode] || mode.toUpperCase(),\n    };\n  } catch {\n    return undefined;\n  }\n}\n"
    }
  },
  "playbackConfig": {
    "speed": 1.0
  },
  "layout": "Tab!mainTab"
}
