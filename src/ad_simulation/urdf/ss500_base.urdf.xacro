<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ss500">

  <!-- SS500 Agricultural Tractor - Base URDF -->
  <!-- Dimensions based on typical small agricultural tractor -->

  <!-- Properties -->
  <xacro:property name="base_length" value="2.5"/>    <!-- m -->
  <xacro:property name="base_width" value="1.4"/>     <!-- m -->
  <xacro:property name="base_height" value="1.2"/>    <!-- m -->
  <xacro:property name="base_mass" value="800"/>      <!-- kg -->
  
  <xacro:property name="wheel_radius" value="0.4"/>   <!-- m -->
  <xacro:property name="wheel_width" value="0.25"/>   <!-- m -->
  <xacro:property name="wheel_mass" value="30"/>      <!-- kg -->
  
  <xacro:property name="wheelbase" value="1.6"/>      <!-- m -->
  <xacro:property name="track_width" value="1.2"/>    <!-- m -->

  <!-- Materials -->
  <material name="green">
    <color rgba="0.2 0.6 0.2 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="glass">
    <color rgba="0.8 0.9 1.0 0.6"/>
  </material>

  <!-- Base Link -->
  <link name="base_footprint">
    <visual>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
    </visual>
  </link>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.6" rpy="0 0 0"/>
      <mass value="${base_mass}"/>
      <inertia ixx="100" ixy="0" ixz="0"
               iyy="150" iyz="0"
               izz="100"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.6" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.6" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.4" rpy="0 0 0"/>
  </joint>

  <!-- Wheels -->
  <xacro:macro name="wheel" params="name x y side">
    <link name="${name}_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${wheel_mass}"/>
        <inertia ixx="1.0" ixy="0" ixz="0"
                 iyy="1.5" iyz="0"
                 izz="1.0"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel"/>
      <origin xyz="${x} ${y} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- 4 Wheels -->
  <xacro:wheel name="front_left" x="${wheelbase/2}" y="${track_width/2}" side="left"/>
  <xacro:wheel name="front_right" x="${wheelbase/2}" y="${-track_width/2}" side="right"/>
  <xacro:wheel name="rear_left" x="${-wheelbase/2}" y="${track_width/2}" side="left"/>
  <xacro:wheel name="rear_right" x="${-wheelbase/2}" y="${-track_width/2}" side="right"/>

  <!-- Camera Mount -->
  <link name="camera_mount">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.3"/>
      </geometry>
      <material name="grey"/>
    </visual>
  </link>
  <joint name="camera_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_mount"/>
    <origin xyz="1.0 0 1.2" rpy="0 0 0"/>
  </joint>

  <!-- GPS/IMU Mount -->
  <link name="gps_imu_mount">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
      <material name="grey"/>
    </visual>
  </link>
  <joint name="gps_imu_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gps_imu_mount"/>
    <origin xyz="-0.5 0 1.25" rpy="0 0 0"/>
  </joint>

</robot>
