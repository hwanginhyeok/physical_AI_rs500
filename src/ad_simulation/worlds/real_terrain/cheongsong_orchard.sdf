        <visual name="roof">
          <pose>0 0 3.3 0 0 0</pose>
          <geometry><box><size>13.0 9.0 0.3</size></box></geometry>
          <material>
            <ambient>0.3 0.15 0.08 1</ambient>
            <diffuse>0.4 0.2 0.1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

