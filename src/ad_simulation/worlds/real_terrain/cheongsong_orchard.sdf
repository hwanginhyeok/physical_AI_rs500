    <model name="farm_barn">
      <static>true</static>
      <pose>127.5 -120.0 2.5 0 0 0.15</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>12.0 8.0 5.0</size></box></geometry>
        </collision>
        <visual name="walls">
          <geometry><box><size>12.0 8.0 5.0</size></box></geometry>
          <material>
            <ambient>0.55 0.45 0.30 1</ambient>
            <diffuse>0.65 0.55 0.40 1</diffuse>
          </material>
